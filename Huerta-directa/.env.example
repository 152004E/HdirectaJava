# ==========================================
# VARIABLES DE ENTORNO PARA RAILWAY (PRODUCCIÓN)
# ==========================================
# IMPORTANTE: Configura estas variables en Railway para que el envío de correos funcione en producción

# Puerto de la aplicación (Railway lo asigna automáticamente)
PORT=8080

# Base de datos PostgreSQL (Railway)
# Nota: Railway provee automáticamente estas variables si usas su servicio de PostgreSQL

# Ruta de uploads en Railway
UPLOAD_PATH=/app/uploads

# MercadoPago - Credenciales de producción
MERCADOPAGO_ACCESS_TOKEN=tu_access_token_de_produccion
MERCADOPAGO_PUBLIC_KEY=tu_public_key_de_produccion

# ==========================================
# CONFIGURACIÓN DE CORREO ELECTRÓNICO (SMTP)
# ==========================================
# Estas variables son OBLIGATORIAS para que funcione el envío de correos en producción

# Host del servidor SMTP (Gmail por defecto)
MAIL_SMTP_HOST=smtp.gmail.com

# Puerto SMTP (587 para TLS)
MAIL_SMTP_PORT=587

# Email desde el cual se enviarán los correos
MAIL_SMTP_USERNAME=hdirecta@gmail.com

# Contraseña de aplicación de Gmail
# IMPORTANTE: NO uses tu contraseña normal de Gmail
# Debes generar una "Contraseña de aplicación" en tu cuenta de Google:
# 1. Ve a https://myaccount.google.com/security
# 2. Activa "Verificación en 2 pasos" si no está activada
# 3. Busca "Contraseñas de aplicaciones"
# 4. Genera una contraseña para "Correo" y "Otro (nombre personalizado)"
# 5. Copia la contraseña generada (sin espacios) y úsala aquí
MAIL_SMTP_PASSWORD=tu_contraseña_de_aplicacion_de_gmail

# ==========================================
# CÓMO CONFIGURAR EN RAILWAY
# ==========================================
# 1. Ve a tu proyecto en Railway
# 2. Selecciona tu servicio
# 3. Ve a "Variables" o "Settings"
# 4. Agrega cada una de estas variables con sus respectivos valores
# 5. Redeploya la aplicación para que tome los cambios
